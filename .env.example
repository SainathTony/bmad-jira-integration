# ── Jira (required when provider = "jira") ───────────────────────────────────
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ── Trello (required when provider = "trello") ────────────────────────────────
# API key: https://trello.com/power-ups/admin → your Power-Up → API key
# Token:   https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_API_KEY
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
